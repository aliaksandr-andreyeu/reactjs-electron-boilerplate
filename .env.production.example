# Copy to .env.production for local production builds (npm run build:web, npm run package)
# Do NOT commit .env.production if it contains SENTRY_AUTH_TOKEN.

# Sentry — build-time (source maps upload)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org
SENTRY_PROJECT=api-client

# Sentry — runtime (also used for Electron main via vite.main.config)
SENTRY_DSN=
VITE_SENTRY_DSN=

# PostHog — runtime
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Web CORS proxy (optional)
VITE_CORS_PROXY_URL=
