    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "electron": "42.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "playwright": "^1.48.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "typesync": "^0.14.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
