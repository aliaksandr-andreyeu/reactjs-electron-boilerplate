{
  "name": "reactjs-electron-boilerplate",
  "productName": "reactjs-electron-boilerplate",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "clean": "rimraf ./.vite ./out ./dist-web",
    "start": "electron-forge start",
    "dev:web": "vite --config vite.config.web.ts --mode development",
    "build:web": "vite build --config vite.config.web.ts --mode production",
    "preview:web": "vite preview --config vite.config.web.ts --mode production",
    "analyze:web": "ANALYZE=true npm run build:web",
    "size:web": "size-limit",
    "lhci": "lhci autorun",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "pretest:e2e": "npm run package",
    "test:e2e": "playwright test",
    "test:e2e:web": "playwright test --config playwright.config.web.ts",
    "postinstall": "npx typesync"
  },
  "keywords": [],
  "author": {
    "name": "Aliaksandr Andreyeu",
    "email": "andreyeu.aliaksandr@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^2.1.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@size-limit/file": "^12.1.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/electron-store": "^3.2.2",
    "@types/eslint": "~9.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "42.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "playwright": "^1.48.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.3",
    "typesync": "^0.14.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.101.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "posthog-js": "^1.382.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  }
}
